<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="content" method="upgrade" version="4.0">
    <name>PLG_CONTENT_STPAGEFLIP</name>
    <element>stpageflip</element>
    <author>Andreas Rottmann</author>
    <version>2.0</version>
    <description>PLG_CONTENT_STPAGEFLIP_XML_DESCRIPTION</description>
    <scriptfile>script.php</scriptfile>
    <services>
        <serviceprovider file="services/provider.php" />
    </services>
    <namespace path="src">Joomla\Plugin\Content\Stpageflip</namespace>
    <files>
        <folder plugin="stpageflip">services</folder>
        <folder>src</folder>
        <folder>language</folder>
    </files>
    <media destination="plg_content_stpageflip" folder="media">
        <folder>admin</folder>
        <folder>css</folder>
        <folder>js</folder>
        <folder>sounds</folder>
        <file>joomla.asset.json</file>
    </media>
    <languages folder="language">
        <language tag="en-GB">en-GB/plg_content_stpageflip.ini</language>
        <language tag="de-DE">de-DE/plg_content_stpageflip.ini</language>
        <language tag="en-GB">en-GB/plg_content_stpageflip.sys.ini</language>
        <language tag="de-DE">de-DE/plg_content_stpageflip.sys.ini</language>
    </languages>
    <config>
        <fields name="params" addfieldprefix="Joomla\Plugin\Content\Stpageflip\Field">
            <fieldset name="basic" label="PLG_CONTENT_STPAGEFLIP_FIELDSET_BASIC">
                <field
                    name="load_jquery"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_CONTENT_STPAGEFLIP_LOAD_JQUERY_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_LOAD_JQUERY_DESC"
                    default="0"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="load_jqueryui"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_CONTENT_STPAGEFLIP_LOAD_JQUERYUI_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_LOAD_JQUERYUI_DESC"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="load_bootstrap"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_CONTENT_STPAGEFLIP_LOAD_BOOTSTRAP_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_LOAD_BOOTSTRAP_DESC"
                    default="0"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="load_bootstrap_icons"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_CONTENT_STPAGEFLIP_LOAD_ICONS_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_LOAD_ICONS_DESC"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="debug_mode"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_CONTENT_STPAGEFLIP_DEBUG_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_DEBUG_DESC"
                    default="0"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
            <fieldset name="conversion" label="PLG_CONTENT_STPAGEFLIP_CONVERSION_TITLE">
                <field
                    name="conversion_format"
                    type="list"
                    label="PLG_CONTENT_STPAGEFLIP_CONV_FORMAT_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_CONV_FORMAT_DESC"
                    default="webp"
                >
                    <option value="webp">WebP</option>
                    <option value="jpeg">JPEG</option>
                    <option value="png">PNG</option>
                </field>
                <field
                    name="conversion_quality"
                    type="number"
                    label="PLG_CONTENT_STPAGEFLIP_CONV_QUALITY_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_CONV_QUALITY_DESC"
                    default="85"
                    min="1"
                    max="100"
                    step="1"
                />
                <field
                    name="conversion_dpi"
                    type="number"
                    label="PLG_CONTENT_STPAGEFLIP_CONV_DPI_LABEL"
                    description="PLG_CONTENT_STPAGEFLIP_CONV_DPI_DESC"
                    default="150"
                    min="72"
                    max="600"
                    step="1"
                />
                <field
                    name="conversion"
                    type="Pageflipconversion"
                    label=""
                />
            </fieldset>
        </fields>
    </config>
</extension>
